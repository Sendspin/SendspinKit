# SwiftFormat Configuration for SendspinKit

--swiftversion 6.1
--exclude .build,Examples

# Trailing commas: never (matches SwiftLint trailing_comma rule)
--trailingcommas never

# Disable rules that conflict with SwiftLint or our style
--disable wrapMultilineStatementBraces

# Self: remove redundant self (Swift default)
--self remove

# Number formatting: group large numbers with underscores
--decimalgrouping 3
--hexgrouping 4
--binarygrouping 4
--octalgrouping 4

# Wrapping
--maxwidth 150
--wraparguments before-first
--wrapparameters before-first
--wrapcollections before-first

# Imports: sort alphabetically
--importgrouping alpha
